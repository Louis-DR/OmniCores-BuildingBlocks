                style  = "text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=6;fontStyle=0;fontColor=black;connectable=0;">
          <mxGeometry x      = "90"
                      y      = "16"
                      width  = "90"
                      height = "0"
                      as     = "geometry"/>
        </mxCell>
            <mxCell id     = "array-label"
